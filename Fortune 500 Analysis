----------------------My Fortune 500 Analysis Query SQL:-----------------------





---Query #1: View all data 

SELECT company_name , industry ,revenue
FROM fortune_companies
;

------'Basic filtering'----- 

--Query 2: Which of the following are in the Technology industry?
SELECT company_name 
FROM fortune_companies 
WHERE industry = 'Technology';

---Basic filtering Query 3: Which companies have revenue greater than 300?
SELECT company_name , revenue
FROM fortune_companies
WHERE revenue > 300
ORDER BY revenue DESC;



---Basic filtering Query 4: Which company have more than 10,000 employees AND revenue > 200?
SELECT company_name , employees
FROM fortune_companies
WHERE employees > 10000
AND revenue > 200
ORDER BY employees DESC;
--INSIGHTS: Technology and energy companies may require fewer employees to generate large revenue compared to retail and logistics heavy industries.--INSIGHTS:

---Basic filtering Query 5: Which companies are in Healthcare OR Finance?
SELECT company_name , industry 
FROM fortune_companies
WHERE industry = 'Healthcare'
OR industry = 'Finance'
;



------Business insight------

--Query 6: Which companies are in the Technology industry AND offer more than 20 paid time off days?
SELECT company_name , industry , paid_time_off_days
FROM fortune_companies
WHERE industry = 'Technology'
AND paid_time_off_days > 20
ORDER BY paid_time_off_days DESC;
--INSIGHTS: Companies offering 22-24 PTO days may prioritize employee well-being and work life balance as part of their organizational culture.

------'Pattern and Sets'------

--Query 7: Which companies have names starting with "A" ?
SELECT company_name
FROM fortune_companies
WHERE company_name LIKE 'A%'
;



---Query 8: Which companies contain "Inc" in their name?
SELECT company_name
FROM fortune_companies
