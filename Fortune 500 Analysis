------'Business insights'---- 

--Which companies have high revenue but low emoplyee count?

--Query 11: first i Found the average of employees and revenue so you'll know waht to consider "high or low"
SELECT AVG(employees)
FROM fortune_companies;

--Query 12: then look for the average revenue 
SELECT AVG(revenue)
FROM fortune_companies;

--Query 13 OUTPUT: High revenue but low employee count found
SELECT company_name , revenue , employees
FROM fortune_companies
WHERE revenue > 260
AND employees < 10000
ORDER BY revenue DESC, employees DESC;
--INSIGHTS: Output could suggest that companies with high revenue and low employee count may indicate strong operational efficency or high value business models.

--Query 14: Which companies offer healthcare benefits?
SELECT company_name , healthcare_benefits
FROM fortune_companies
WHERE healthcare_benefits = 1;

--Query 15: Which companies have NO Healthcare benifits? 
SELECT company_name , healthcare_benefits
FROM fortune_companies 
WHERE healthcare_benefits = 0;

---Query 16: Show companies with and without healthcare beneffits
SELECT company_name , healthcare_benefits ,
CASE 
WHEN healthcare_benefits = 1 THEN 'YES'
ELSE 'NO'
END AS benefits_status
FROM fortune_companies;

---Which companies have long employee tenure
 
--Query 17: first find out the average tenure years to
SELECT AVG(avg_employee_tenure)
FROM fortune_companies;

--Query 18: employee tenure arranged in descending order
SELECT company_name, 
avg_employee_tenure AS Avg_Tenure_Years
FROM fortune_companies
WHERE avg_employee_tenure > 6
ORDER BY avg_employee_tenure DESC;
--INSIGHTS: A workforce with longer tenure may contribute to greater institutional knowledge, operational consistency and reduced training costs.



-------Calculated business metrics--------


---What is the revenue per employee?

--Query 19: revenue calculation
SELECT revenue / employees
FROM fortune_companies;
--Output did not give give full insight here so ill use better identifiers and context.

--Query 20: organized the revenue more efficently per employee and company.
SELECT company_name, revenue, employees,
ROUND(revenue / employees , 2) AS revenue_per_employee
FROM fortune_companies
ORDER BY revenue_per_employee DESC;

---Which companies are MOST efficient? 

--Query 21: basically look for companies with most efficent numbers 
SELECT company_name , revenue , employees,
ROUND(revenue / employees, 2) AS Revenue_Per_Employee
FROM fortune_companies
ORDER BY Revenue_Per_Employee DESC;
--INSIGHTS: Companies with higher revenue per employee may operate more efficiently by generating strong financial performance with smaller workforces


---Which companies are LEAST efficient?

--Query 22: Ascending order will reveal the least to most in that order
SELECT company_name , revenue , employees,
ROUND(revenue / employees, 2) AS Revenue_Per_Employee
FROM fortune_companies
ORDER BY Revenue_Per_Employee ASC;
--INSIGHTS: companies with lower revenue per employee may rely more heavily on customer facing roles and physical operations rather than scalable digital services.


-----Using CASE statments to categorize data-----


--Categorize companies

--Query 23: First i want to know the average revenue per company to categorize high and low revenue 
SELECT AVG(Revenue)
FROM fortune_companies;

--Query 24: now i can give case output an alias and order the descending groups
SELECT company_name, revenue,
CASE
WHEN revenue > 300 THEN 'High Revenue'
WHEN revenue > 200 THEN 'Medium Revenue'
ELSE 'Low Revenue'
END AS revenue_category 
FROM fortune_companies
ORDER BY revenue_category , revenue DESC;
