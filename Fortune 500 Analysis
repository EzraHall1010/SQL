-----HAVING mindset-------

--Query 29: which industries have companies with average revenue greater than 259 (general average revenue)

--First i summarized the industries in order to filter the metrics and then compared grouped performances
SELECT industry,
ROUND(AVG(revenue), 2) AS avg_revenue
FROM fortune_companies
GROUP BY industry
HAVING ROUND(AVG(revenue), 2) > 259
ORDER BY avg_revenue DESC;
--INSIGHTS: Technology, Manufacturing and Energy industries have the highest revenue, this could impy that industries connected to innovation, production and essential resources tend to generate larger revenue at scale.

--Which industries have high employee tenure overall?

--Query 30: first define the highest tenures 
SELECT AVG(avg_employee_tenure)
FROM fortune_companies;
--average employee tenure is 6yrs

--Query 31: 
SELECT industry,
ROUND(AVG(avg_employee_tenure),2) AS avg_industry_tenure
FROM fortune_companies
GROUP BY industry
HAVING AVG(avg_employee_tenure) > 6 
ORDER BY avg_industry_tenure DESC;
--INSIGHTS: Financials, Energy and Manufacturning industries all have the highest employee tenure overall which may suggest stronger long-term employee retention, stable career paths or industries where experience is highly valued.

--Query 32: Which industries have an average PTO allowance greater than 20 days?

SELECT industry,
ROUND(AVG(paid_time_off_days),2) AS avg_pto_days
FROM fortune_companies
GROUP BY industry
HAVING AVG(paid_time_off_days) > 20
ORDER BY avg_pto_days DESC;
--INSIGHTS: Manufacturing appearing in the top 3 could suggest that even physcially demanding workforces are investing into employee benifits to maintain reliability and productivity.

--Which industries employ more than 100000 employees total?

SELECT industry,
ROUND(SUM(employees),2) AS total_employees
FROM fortune_companies
GROUP BY industry
HAVING SUM(employees) > 100000
ORDER BY total_employees DESC;
--INSIGHTS: Retail, Technology, Financials and Telecommunications all lead the top total employees, suggesting these industries require significant operational support,customer service, and large scale business infrastructure
